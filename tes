import cv2
import urllib.request
import numpy as np

# Link unduhan langsung dari database standar USC-SIPI (University of Southern California)
gambar_uji = {
    "Lena_512.png": "https://sipi.usc.edu/database/download.php?vol=misc&img=4.2.04",
    "Mandrill_512.png": "https://sipi.usc.edu/database/download.php?vol=misc&img=4.2.03",
    "Peppers_512.png": "https://sipi.usc.edu/database/download.php?vol=misc&img=4.2.07"
}

for nama, url in gambar_uji.items():
    print(f"Mengunduh {nama}...")
    try:
        req = urllib.request.urlopen(url)
        arr = np.asarray(bytearray(req.read()), dtype=np.uint8)
        img = cv2.imdecode(arr, cv2.IMREAD_COLOR)
        # Otomatis menyimpan sebagai PNG murni (Lossless)
        cv2.imwrite(nama, img)
        print(f"✅ Berhasil disimpan sebagai {nama} (Ukuran: {img.shape[1]}x{img.shape[0]})")
    except Exception as e:
        print(f"❌ Gagal mengunduh {nama}: {e}")